# Cloud template only.
# Copy the values you want into `.env`, or export this file before running the app.
# Example:
#   cp .env.cloud .env
# or:
#   set -a; source .env.cloud; set +a

LAUNCHER_PROFILE=cloud
STORAGE_BACKEND=r2
QDRANT_BACKEND=cloud

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=replace_me
QDRANT_COLLECTION=summarizer_docs

# Cloudflare R2
R2_ACCOUNT_ID=replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_BUCKET=replace_me
R2_PUBLIC_BASE_URL=https://pub-example.r2.dev

# Summarization provider
LLM_PROVIDER=groq
LLM_ENABLE_FALLBACK=True
LLM_FALLBACK_CHAIN=groq,gemini,nvidia,openrouter
LLM_REQUEST_TIMEOUT_SECONDS=30

GROQ_API_KEY=replace_me
GROQ_MODEL=openai/gpt-oss-120b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding runtime
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIM=768
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_DEVICE=cpu
EMBEDDING_LOCAL_FILES_ONLY=False
EMBEDDING_TRUST_REMOTE_CODE=True
EMBEDDING_TRUST_REMOTE_CODE_ALLOWED_MODELS=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_ONNX_ALLOWED_MODELS=sentence-transformers/all-MiniLM-L6-v2

# NLP
SPACY_MODEL=en_core_web_sm

# Image export
DOCLING_IMAGE_DIR=output/images
DOCLING_IMAGE_MODE=local
EXPORT_PAGE_IMAGES=False
EXPORT_EMBEDDED_IMAGES=True
ENABLE_FALLBACK_RENDER=False
MAX_FALLBACK_PAGES=5
FALLBACK_RENDER_DPI=120
ENABLE_ON_DEMAND_PAGE_RENDER=True
